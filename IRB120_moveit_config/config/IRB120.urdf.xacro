<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="IRB120">
    <xacro:arg name="initial_positions_file" default="initial_positions.yaml" />

    <!-- Import IRB120 urdf file -->
    <xacro:include filename="$(find IRB120)/urdf/IRB120.urdf.xml" />

    <!-- Import control_xacro -->
    <xacro:include filename="IRB120.ros2_control.xacro" />


    <xacro:IRB120_ros2_control name="FakeSystem" initial_positions_file="$(arg initial_positions_file)"/>

</robot>
